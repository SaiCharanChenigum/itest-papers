generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION MODELS
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  password      String?   // For email/password authentication fallback
  role          UserRole  @default(STUDENT)
  phone         String?

  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  payments      Payment[]
  cartItems     CartItem[]
  orders        DeliveryOrder[]

  @@index([email])
}

enum UserRole {
  STUDENT
  ADMIN
}

// NextAuth.js Models
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// COURSE CONTENT MODELS
// ============================================

model Subject {
  id          String   @id @default(uuid())
  name        String   // Biology / Chemistry
  class       Int      // 9 or 10
  description String?
  isActive    Boolean  @default(true)
  imageUrl    String?  // Subject icon/image

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapters Chapter[]

  @@index([class, isActive])
}

model Chapter {
  id          String   @id @default(uuid())
  title       String
  description String?
  order       Int      // Display order within subject

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contents Content[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([subjectId, order])
}

model Content {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        ContentType
  fileUrl     String      // Path or URL to PDF file
  isFree      Boolean     @default(false)
  order       Int         @default(0) // Display order within chapter

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId, order])
  @@index([isFree])
}

enum ContentType {
  NOTES
  TEST_PAPER
  SOLUTION
  SAMPLE_PAPER
}

// ============================================
// PAYMENT & SUBSCRIPTION MODELS
// ============================================

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  planName    String   // e.g., "Class 9 Biology", "Full Access"
  planType    String   // "SUBJECT" or "FULL_ACCESS"
  subjectId   String?  // If subject-specific subscription
  class       Int?     // 9 or 10
  amount      Float    // Amount paid in INR
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(true)

  paymentId String?  @unique // Link to payment record
  payment   Payment? @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([endsAt])
}

model Payment {
  id                  String        @id @default(uuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Razorpay details
  razorpayOrderId     String        @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?
  
  amount              Float         // Amount in INR
  currency            String        @default("INR")
  status              PaymentStatus @default(PENDING)
  
  // Payment metadata
  planName            String
  planType            String
  subjectId           String?
  class               Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription?

  @@index([userId, status])
  @@index([razorpayOrderId])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ==========================================
// E-COMMERCE & BOOK DELIVERY MODELS
// ==========================================

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  chapterId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@map("cart_items")
}

enum DeliveryOrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  ONLINE
}

model DeliveryOrder {
  id            String              @id @default(cuid())
  orderNumber   String              @unique
  userId        String
  status        DeliveryOrderStatus @default(PROCESSING)
  totalAmount   Float
  deliveryFee   Float               @default(60)
  paymentMethod PaymentMethod
  razorpayId    String?
  
  // Delivery Details
  fullName      String
  phone         String
  address       String
  city          String
  state         String
  pincode       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@map("delivery_orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  chapterId String
  quantity  Int
  priceAt   Float    // ₹99 per chapter

  order   DeliveryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  chapter Chapter       @relation(fields: [chapterId], references: [id])

  @@map("order_items")
}


